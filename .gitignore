# ================================================================
# CyberAI Assessment Platform — .gitignore
# ================================================================
# Policy: push 100% of repo (including AI assistant configs and skills)
# so new dev machines can clone and immediately continue working.
# Only exclude: secrets, user-data runtime artifacts, build outputs, large models.
# ================================================================

# ====== Secrets (NEVER commit) ======
.env
frontend-next/.env.local
*.key
*.pem
*.cert
*.p12
*.secret

# ====== Python ======
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ====== Node.js / Next.js build output ======
node_modules/
.next/
frontend-next/.next/
frontend-next/node_modules/
out/
.turbo/

# ====== Large model weights (too big for git) ======
models/
*.gguf
*.bin
*.safetensors
*.onnx
*.pt
*.pth

# ====== Runtime user data (generated at runtime — each machine has its own) ======
data/sessions/*
!data/sessions/.gitkeep
data/uploads/*
!data/uploads/.gitkeep
data/summaries/*
!data/summaries/.gitkeep
data/summaries/audio/*
data/assessments/*
!data/assessments/.gitkeep
data/exports/*
!data/exports/.gitkeep
data/evidence/*
!data/evidence/.gitkeep
data/articles_history.json
data/translations/*.json
data/standards/*
!data/standards/.gitkeep

# ====== Vector store runtime (rebuilt on startup via reindex) ======
data/vector_store/*.faiss
data/vector_store/chroma.sqlite3
data/vector_store/*/

# ====== IDE / OS / Misc ======
.vscode/
.idea/
.vs/
*.swp
*.swo
.DS_Store
Thumbs.db
hash.txt

# ====== Docker ======
.dockerignore
