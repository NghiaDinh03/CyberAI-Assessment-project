# ======= MODEL & LLM SETTINGS =======
LOCALAI_URL=http://localai:8080
# Ưu tiên chạy model local trước, chỉ fallback cloud khi local lỗi
PREFER_LOCAL=true

# Phase 2 (Report formatting) — Meta-Llama general language model
# RAM: 8B Q4 ~5GB | 70B Q4 ~40GB (KHÔNG dùng được trong container 12GB)
# → Chỉ dùng 8B. Sau khi đổi MODEL_NAME, restart localai container.
MODEL_NAME=Meta-Llama-3.1-8B-Instruct-Q4_K_M.gguf

# Phase 1 (GAP analysis) — SecurityLM 7B ~4GB RAM
SECURITY_MODEL_NAME=SecurityLLM-7B-Q4_K_M.gguf

MAX_TOKENS=-1
DEBUG=true
THREADS=6
CONTEXT_SIZE=8192

# ======= CLOUD LLM API (Open Claude - Primary) =======
CLOUD_LLM_API_URL=https://open-claude.com/v1
CLOUD_MODEL_NAME=gemini-3-flash-preview
CLOUD_API_KEYS=your-cloud-api-key-here

# ======= DATA PATHS =======
ISO_DOCS_PATH=/data/iso_documents
VECTOR_STORE_PATH=/data/vector_store
DATA_PATH=/data

# ======= BACKEND =======
LOG_LEVEL=INFO

# ======= SECURITY =======
CORS_ORIGINS=http://localhost:3000
# JWT_SECRET: Must be at least 32 characters, no default allowed.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# The application will refuse to start if this is missing, set to a known weak
# value ("changeme", "secret", "your-secret-key"), or shorter than 32 chars.
JWT_SECRET=change-me-in-production
JWT_EXPIRE_MINUTES=60

# ======= RATE LIMITING =======
RATE_LIMIT_CHAT=10/minute
RATE_LIMIT_ASSESS=3/minute
RATE_LIMIT_BENCHMARK=5/minute

# ======= PERFORMANCE =======
# INFERENCE_TIMEOUT: thời gian chờ 1 request LocalAI (giây)
# Chunked assessment: 4 chunks × ~60s/chunk = 240s tối đa → đặt 300s để an toàn
INFERENCE_TIMEOUT=300
CLOUD_TIMEOUT=60
MAX_CONCURRENT_REQUESTS=3
