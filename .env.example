# ======= MODEL & LLM SETTINGS =======
LOCALAI_URL=http://localai:8080
MODEL_NAME=Meta-Llama-3.1-70B-Instruct-Q4_K_M.gguf
SECURITY_MODEL_NAME=SecurityLLM-7B-Q4_K_M.gguf
MAX_TOKENS=-1
DEBUG=true
THREADS=6
CONTEXT_SIZE=8192

# ======= CLOUD LLM API (Open Claude - Primary) =======
CLOUD_LLM_API_URL=https://open-claude.com/v1
CLOUD_MODEL_NAME=claude-opus-4.6
CLOUD_API_KEYS=your-cloud-api-key-here

# ======= OPENROUTER API (Fallback) =======
OPENROUTER_API_KEYS=your-openrouter-api-key-here
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_API_URL=https://openrouter.ai/api/v1

# ======= GEMINI (Optional Fallback) =======
GEMINI_API_KEYS=your-gemini-api-key-here

# ======= DATA PATHS =======
ISO_DOCS_PATH=/data/iso_documents
VECTOR_STORE_PATH=/data/vector_store
DATA_PATH=/data
HF_HOME=/data/models/huggingface

# ======= BACKEND =======
BACKEND_URL=http://backend:8000
LOG_LEVEL=INFO

# ======= SECURITY =======
CORS_ORIGINS=http://localhost:3000
JWT_SECRET=change-me-in-production
JWT_EXPIRE_MINUTES=60

# ======= RATE LIMITING =======
RATE_LIMIT_CHAT=10/minute
RATE_LIMIT_ASSESS=3/minute
RATE_LIMIT_NEWS=5/minute

# ======= PERFORMANCE =======
TORCH_THREADS=4
INFERENCE_TIMEOUT=180
CLOUD_TIMEOUT=60
MAX_CONCURRENT_REQUESTS=3
